# Full SSH Config Test File
# This file covers all common SSH config options

# Wildcard defaults - applies to all hosts
Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3

# Jump host (bastion)
Host jump
    HostName bastion.example.com
    User jumpuser
    Port 22

# Internal host via jump host
Host internal
    HostName 10.0.0.5
    User admin
    ProxyJump jump

# Basic configuration
Host basic-server
    HostName 192.168.1.100
    User admin
    Port 22

# Custom port
Host custom-port
    HostName example.com
    User root
    Port 2222

# Wildcard pattern - dev servers
Host dev-*
    User developer
    Port 2222

# Wildcard pattern - staging servers
Host staging-*
    User deployer
    Port 22

# Wildcard pattern with ? (single character)
Host prod-?
    User admin
    Port 22

# Actual hosts matching wildcard patterns (these should inherit from wildcards)
Host dev-server1
    HostName dev1.example.com

Host dev-server2
    HostName dev2.example.com

Host dev-db
    HostName dev-db.example.com

Host staging-web
    HostName staging-web.example.com

Host staging-api
    HostName staging-api.example.com

Host prod-a
    HostName prod-a.example.com

Host prod-z
    HostName prod-z.example.com

# Identity file (single)
Host with-identity
    HostName server1.example.com
    User deploy
    IdentityFile ~/.ssh/id_rsa

# Multiple identity files
Host multiple-identities
    HostName server2.example.com
    User ubuntu
    IdentityFile ~/.ssh/id_rsa
    IdentityFile ~/.ssh/id_ed25519
    IdentityFile ~/.ssh/id_ecdsa

# Proxy jump (single)
Host via-jump
    HostName internal.server.com
    User admin
    ProxyJump jump.example.com

# Proxy jump (multiple hops)
Host via-multiple-jumps
    HostName deep.internal.com
    User admin
    ProxyJump jump1.example.com,jump2.example.com

# Proxy command
Host via-proxy-command
    HostName proxy-server.com
    User admin
    ProxyCommand nc -X 5 -p 1080 %h %p

# Forward agent
Host with-agent
    HostName agent-server.com
    User admin
    ForwardAgent yes

# Server alive options
Host with-keepalive
    HostName keepalive-server.com
    User admin
    ServerAliveInterval 60
    ServerAliveCountMax 3

# Compression
Host with-compression
    HostName compress-server.com
    User admin
    Compression yes

# Connection attempts and timeout
Host with-timeout
    HostName timeout-server.com
    User admin
    ConnectionAttempts 3
    ConnectTimeout 30

# TCP keepalive
Host with-tcp-keepalive
    HostName tcp-server.com
    User admin
    TCPKeepAlive yes

# Control master
Host with-control-master
    HostName control-server.com
    User admin
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

# Complex host with multiple options
Host complex-server
    HostName 10.0.0.100
    User admin
    Port 22
    IdentityFile ~/.ssh/prod_key
    ForwardAgent yes
    ServerAliveInterval 30
    ServerAliveCountMax 2
    Compression yes
    TCPKeepAlive yes

# Host alias (no hostname, just alias)
Host my-alias
    HostName real-server.example.com
    User admin

# IPv6 address
Host ipv6-server
    HostName 2001:db8::1
    User admin

# Quoted values
Host "quoted server"
    HostName "server with spaces.example.com"
    User "admin user"
    Port "2222"

# SSH Certificate Authentication
Host with-certificate
    HostName 192.168.1.100
    User john
    IdentityFile ./test/id_ed25519_test
    CertificateFile ./test/id_ed25519_test-cert.pub

# Local port forwarding
Host local-forward
    HostName db-server.internal.com
    User admin
    LocalForward 3306 mysql.internal.com:3306
    LocalForward 8080 localhost:8080

# Local port forwarding with bind address
Host local-forward-bind
    HostName app-server.internal.com
    User developer
    LocalForward 0.0.0.0:9000 remote-app:9000

# Remote port forwarding
Host remote-forward
    HostName bastion.example.com
    User admin
    RemoteForward 8080 localhost:3000
    RemoteForward 2222 localhost:22

# Remote port forwarding with bind address
Host remote-forward-bind
    HostName bastion.example.com
    User admin
    RemoteForward 0.0.0.0:8080 localhost:8080

# Dynamic port forwarding (SOCKS proxy)
Host dynamic-forward
    HostName proxy.example.com
    User admin
    DynamicForward 1080

# Dynamic port forwarding with bind address
Host dynamic-forward-bind
    HostName proxy.example.com
    User admin
    DynamicForward 0.0.0.0:1080

# Multiple port forwards combined
Host multi-forward
    HostName server.example.com
    User admin
    LocalForward 3306 mysql.internal.com:3306
    RemoteForward 8080 localhost:3000
    DynamicForward 1080

# Identity Agent
Host with-identity-agent
    HostName server.example.com
    User admin
    IdentityAgent /run/user/1000/gnupg/S.gpg-agent.ssh

# Identities Only
Host identities-only
    HostName server.example.com
    User admin
    IdentitiesOnly yes
    IdentityFile ~/.ssh/id_rsa

# Identity Agent and Identities Only
Host with-agent-config
    HostName server.example.com
    User admin
    IdentityAgent $SSH_AUTH_SOCK
    IdentitiesOnly yes
